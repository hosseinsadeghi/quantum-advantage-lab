# Quantum Advantage Lab -- environment variables
# Copy to .env (or export directly) and fill in values as needed.

# IonQ cloud access. When unset, the backend gracefully falls back to the Aer
# simulator for any "use_simulator=false" request.
IONQ_API_KEY=

# Comma-separated list (or "*" for dev). Used by backend CORS middleware in
# Phase 3 onward; today backend/main.py hard-codes "*".
CORS_ORIGINS=*

# Optional: when the frontend is built for a cross-origin deploy topology
# (Vercel frontend + Railway backend, Phase 5), prepend this to fetch/WS URLs.
# Leave empty for same-origin (Docker compose / local dev).
VITE_BACKEND_URL=
